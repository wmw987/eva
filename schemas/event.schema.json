{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.eva.local/event.schema.json",
  "title": "Eva Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "summary",
    "topic",
    "time",
    "geo",
    "assessment",
    "provenance",
    "relations"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^event_[A-Za-z0-9_-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "time": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed_at", "valid_from", "valid_to", "precision"],
      "properties": {
        "observed_at": { "type": "string", "format": "date-time" },
        "valid_from": { "type": "string", "format": "date-time" },
        "valid_to": {
          "anyOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        },
        "precision": {
          "enum": ["instant", "minute", "hour", "day", "month", "year", "unknown"]
        }
      }
    },
    "geo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "geometry", "centroid", "precision_m"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "country": { "type": ["string", "null"] },
        "region": { "type": ["string", "null"] },
        "geometry": { "$ref": "#/$defs/geometry" },
        "centroid": { "$ref": "#/$defs/centroid" },
        "precision_m": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      }
    },
    "assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk", "confidence"],
      "properties": {
        "risk": { "enum": ["low", "medium", "high", "unknown"] },
        "confidence": { "enum": ["confirmed", "signal", "rumor", "unknown"] }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sources"],
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source" }
        }
      }
    },
    "relations": {
      "type": "array",
      "items": { "$ref": "#/$defs/relation" }
    }
  },
  "$defs": {
    "centroid": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lat", "lon"],
      "properties": {
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "geometry": {
      "oneOf": [
        { "$ref": "#/$defs/point" },
        { "$ref": "#/$defs/lineString" },
        { "$ref": "#/$defs/polygon" },
        { "$ref": "#/$defs/multiPolygon" }
      ]
    },
    "position": {
      "type": "array",
      "prefixItems": [
        { "type": "number", "minimum": -180, "maximum": 180 },
        { "type": "number", "minimum": -90, "maximum": 90 }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "Point" },
        "coordinates": { "$ref": "#/$defs/position" }
      }
    },
    "lineString": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "LineString" },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/position" }
        }
      }
    },
    "linearRing": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/position" }
    },
    "polygon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "Polygon" },
        "coordinates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/linearRing" }
        }
      }
    },
    "multiPolygon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "MultiPolygon" },
        "coordinates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/linearRing" }
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "ref", "retrieved_at"],
      "properties": {
        "type": { "enum": ["synthetic-report", "manual-note", "test-fixture"] },
        "ref": { "type": "string", "minLength": 1 },
        "retrieved_at": { "type": "string", "format": "date-time" }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "target_id"],
      "properties": {
        "type": {
          "enum": ["mentions", "affects", "contradicts", "supersedes", "related_to"]
        },
        "target_id": { "type": "string", "minLength": 1 }
      }
    }
  }
}
